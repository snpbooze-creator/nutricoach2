rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isNutritionist() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'nutritionist';
    }

    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Clients: any auth user can read; only nutritionists can write;
    // clients can update or delete their own record
    match /clients/{clientId} {
      allow read:   if request.auth != null;
      allow write:  if isNutritionist();
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Meal plans: read by any auth user; write only by nutritionists
    match /mealPlans/{planId} {
      allow read:  if request.auth != null;
      allow write: if isNutritionist();
    }

    // Check-ins: any authenticated user can read and write
    match /checkIns/{checkInId} {
      allow read, write: if request.auth != null;
    }

    // Templates: any auth user can read; write only by nutritionists
    match /mealPlanTemplates/{tplId} {
      allow read:  if request.auth != null;
      allow write: if isNutritionist();
    }

    // Measurements: read by any auth user; write only by nutritionists
    match /measurements/{measId} {
      allow read:  if request.auth != null;
      allow write: if isNutritionist();
    }

    // Meal check ticks: any authenticated user can read and write
    match /mealChecks/{checkId} {
      allow read, write: if request.auth != null;
    }

    // Appointments: any authenticated user can read and write
    match /appointments/{apptId} {
      allow read, write: if request.auth != null;
    }

    // NEW FEATURE — Recipes: read by auth, write only by nutritionists
    match /recipes/{recipeId} {
      allow read:  if request.auth != null;
      allow write: if isNutritionist();
    }

    // NEW FEATURE — Weekend risks: any authenticated user can read and write
    match /weekendRisks/{riskId} {
      allow read, write: if request.auth != null;
    }

    // NEW FEATURE — Meal photos: any authenticated user can read and write
    match /mealPhotos/{photoId} {
      allow read, write: if request.auth != null;
    }
  }
}
